# Sid chatbot — set ANY ONE of these keys. Priority: Groq → Gemini → Anthropic.
# Without a key the site still works; the chat widget shows a contact fallback.

# Groq (recommended, free, no credit card) — console.groq.com
GROQ_API_KEY=

# Google Gemini (free tier) — aistudio.google.com
GEMINI_API_KEY=

# Anthropic Claude — console.anthropic.com
ANTHROPIC_API_KEY=

# Optional overrides
# CHAT_PROVIDER=groq            # force a provider when multiple keys are set
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ALLOWED_ORIGIN=https://lakshita-singhi.vercel.app   # scope CORS in prod
